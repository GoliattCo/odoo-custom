# Required Fly secrets for odoo-saas-slack-intake.
# DO NOT commit a filled-in version of this file.
#
# Apply with:
#   flyctl secrets set --app odoo-saas-slack-intake \
#     SLACK_BOT_TOKEN=... \
#     SLACK_SIGNING_SECRET=... \
#     GITHUB_TOKEN=... \
#     GITHUB_WEBHOOK_SECRET=...
#
# Rotation cadence:
#   SLACK_BOT_TOKEN          — only when revoked
#   SLACK_SIGNING_SECRET     — only when revoked (Slack does not auto-rotate)
#   GITHUB_TOKEN             — 90 days (PAT expiry)
#   GITHUB_WEBHOOK_SECRET    — quarterly

SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_WEBHOOK_SECRET=REPLACE_ME

# Optional override — set to "false" to disable the whole bot at runtime.
# (The repo variable AGENTS_ENABLED gates new DEPLOYS; this flag gates a
# running instance.)
# AGENTS_ENABLED=true

# Optional: switch off the Phase-B "shadow mode" by setting this to "false".
# Phase C is enabled by setting it to "false" and re-deploying.
# AGENTS_AGENTS_SLACK_INTAKE_SHADOW_MODE=true
