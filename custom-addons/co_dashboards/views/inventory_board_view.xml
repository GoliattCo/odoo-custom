<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="inventory_board_view" model="ir.ui.view">
        <field name="name">Tablero de Inventario</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Tablero de Inventario">
                <board style="2-1">
                    <column>
                        <action name="%(co_dashboards.action_dashboard_stock_category)d"
                                string="Stock por Categoría de Producto"/>
                        <action name="%(co_dashboards.action_dashboard_stock_moves)d"
                                string="Movimientos de Stock por Tipo"/>
                        <action name="%(co_dashboards.action_dashboard_stock_valuation)d"
                                string="Valoración de Inventario"/>
                    </column>
                    <column>
                        <action name="%(co_dashboards.action_dashboard_pickings_state)d"
                                string="Transferencias por Estado"/>
                        <action name="%(co_dashboards.action_dashboard_kardex)d"
                                string="Kardex - Entradas y Salidas"/>
                        <action name="%(co_dashboards.action_dashboard_reorder)d"
                                string="Productos por Reabastecer"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_inventory_board" model="ir.actions.act_window">
        <field name="name">Tablero de Inventario</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="inventory_board_view"/>
    </record>
</odoo>
