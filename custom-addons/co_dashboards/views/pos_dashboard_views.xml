<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Búsqueda compartida para todos los KPIs de POS               -->
    <!-- ============================================================ -->
    <record id="dashboard_pos_search" model="ir.ui.view">
        <field name="name">dashboard.pos.search</field>
        <field name="model">report.pos.order</field>
        <field name="arch" type="xml">
            <search string="Punto de Venta">
                <field name="product_id"/>
                <field name="config_id"/>
                <field name="user_id"/>
                <separator/>
                <filter name="paid_done" string="Pagados"
                        domain="[('state', 'in', ('paid', 'done'))]"/>
                <separator/>
                <filter name="this_month" string="Este Mes"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- KPI 1: Ventas por Categoría                                  -->
    <!-- ============================================================ -->
    <record id="view_dashboard_pos_category_graph" model="ir.ui.view">
        <field name="name">report.pos.order.category.dashboard.graph</field>
        <field name="model">report.pos.order</field>
        <field name="arch" type="xml">
            <graph string="Ventas por Categoría" type="bar">
                <field name="product_categ_id" type="row"/>
                <field name="price_total" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_dashboard_pos_category_pivot" model="ir.ui.view">
        <field name="name">report.pos.order.category.dashboard.pivot</field>
        <field name="model">report.pos.order</field>
        <field name="arch" type="xml">
            <pivot string="Ventas por Categoría">
                <field name="product_categ_id" type="row"/>
                <field name="price_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_dashboard_pos_category" model="ir.actions.act_window">
        <field name="name">Ventas por Categoría</field>
        <field name="res_model">report.pos.order</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="dashboard_pos_search"/>
        <field name="context">{'search_default_this_month': 1, 'search_default_paid_done': 1}</field>
    </record>

