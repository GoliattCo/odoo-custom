<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_board_view" model="ir.ui.view">
        <field name="name">Tablero POS</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Tablero POS">
                <board style="2-1">
                    <column>
                        <action name="%(co_dashboards.action_dashboard_pos_category)d"
                                string="Ventas por Categoría"/>
                        <action name="%(co_dashboards.action_dashboard_pos_trend)d"
                                string="Tendencia de Ventas"/>
                        <action name="%(co_dashboards.action_dashboard_pos_top_products)d"
                                string="Productos Más Vendidos"/>
                    </column>
                    <column>
                        <action name="%(co_dashboards.action_dashboard_pos_config)d"
                                string="Ventas por Punto de Venta"/>
                        <action name="%(co_dashboards.action_dashboard_pos_payment)d"
                                string="Ventas por Método de Pago"/>
                        <action name="%(co_dashboards.action_dashboard_pos_margin)d"
                                string="Margen por Categoría"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_pos_board" model="ir.actions.act_window">
        <field name="name">Tablero POS</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="pos_board_view"/>
    </record>
</odoo>
