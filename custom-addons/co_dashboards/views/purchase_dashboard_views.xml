                <field name="co_fulfillment_state" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_dashboard_po_fulfillment_search" model="ir.ui.view">
        <field name="name">purchase.order.fulfillment.dashboard.search</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <search string="Cumplimiento OC">
                <filter name="confirmed" string="Confirmadas"
                        domain="[('state', '=', 'purchase')]"/>
            </search>
        </field>
    </record>

    <record id="action_dashboard_po_fulfillment" model="ir.actions.act_window">
        <field name="name">Cumplimiento de Órdenes de Compra</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="view_dashboard_po_fulfillment_search"/>
        <field name="domain">[('state', '=', 'purchase')]</field>
        <field name="context">{'search_default_confirmed': 1}</field>
    </record>

