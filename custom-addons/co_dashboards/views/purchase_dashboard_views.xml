    <!-- ============================================================ -->
    <!-- KPI 4: Cumplimiento de Órdenes de Compra                     -->
    <!-- ============================================================ -->
    <record id="view_dashboard_po_fulfillment_graph" model="ir.ui.view">
        <field name="name">purchase.order.fulfillment.dashboard.graph</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <graph string="Cumplimiento de Órdenes de Compra" type="pie">
                <field name="co_fulfillment_state" type="row"/>
            </graph>
        </field>
    </record>

    <record id="view_dashboard_po_fulfillment_pivot" model="ir.ui.view">
        <field name="name">purchase.order.fulfillment.dashboard.pivot</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
