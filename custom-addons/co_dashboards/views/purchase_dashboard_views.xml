<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- KPI 1: Solicitudes de Compra por Estado                      -->
    <!-- ============================================================ -->
    <record id="view_dashboard_purchase_requests_graph" model="ir.ui.view">
        <field name="name">co.purchase.request.dashboard.graph</field>
        <field name="model">co.purchase.request</field>
        <field name="arch" type="xml">
            <graph string="Solicitudes de Compra por Estado" type="bar">
                <field name="state" type="row"/>
                <field name="estimated_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_dashboard_purchase_requests_pivot" model="ir.ui.view">
        <field name="name">co.purchase.request.dashboard.pivot</field>
        <field name="model">co.purchase.request</field>
        <field name="arch" type="xml">
            <pivot string="Solicitudes de Compra por Estado">
                <field name="state" type="row"/>
                <field name="estimated_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_dashboard_purchase_requests_search" model="ir.ui.view">
        <field name="name">co.purchase.request.dashboard.search</field>
        <field name="model">co.purchase.request</field>
        <field name="arch" type="xml">
            <search string="Solicitudes de Compra">
                <field name="department_id"/>
                <filter name="this_month" string="Este Mes"
                        domain="[('date_request', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date_request', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('date_request', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('date_request', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('date_request', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('date_request', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <record id="action_dashboard_purchase_requests" model="ir.actions.act_window">
        <field name="name">Solicitudes de Compra por Estado</field>
        <field name="res_model">co.purchase.request</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="view_dashboard_purchase_requests_search"/>
        <field name="context">{'search_default_this_year': 1}</field>
    </record>

