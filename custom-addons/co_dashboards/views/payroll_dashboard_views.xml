<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== KPI 1: Costo de Nómina por Departamento ==================== -->

    <record id="view_payroll_cost_search" model="ir.ui.view">
        <field name="name">co.payslip.cost.search</field>
        <field name="model">co.payslip</field>
        <field name="arch" type="xml">
            <search string="Costo de Nómina">
                <filter name="this_month" string="Este Mes"
                        domain="[('date_from', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_from', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('date_from', '&gt;=', (context_today() - relativedelta(months=(context_today().month - 1) %% 3, day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_from', '&lt;=', (context_today() + relativedelta(months=2 - (context_today().month - 1) %% 3, day=31)).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('date_from', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_from', '&lt;=', (context_today() + relativedelta(month=12, day=31)).strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <filter name="done" string="Confirmadas"
                        domain="[('state', '=', 'done')]"/>
            </search>
        </field>
    </record>

    <record id="view_payroll_cost_graph" model="ir.ui.view">
        <field name="name">co.payslip.cost.graph</field>
        <field name="model">co.payslip</field>
        <field name="arch" type="xml">
            <graph string="Costo de Nómina por Departamento" type="bar">
                <field name="department_id"/>
                <field name="total_earnings" type="measure"/>
                <field name="total_deductions" type="measure"/>
                <field name="net_pay" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_payroll_cost_pivot" model="ir.ui.view">
        <field name="name">co.payslip.cost.pivot</field>
        <field name="model">co.payslip</field>
        <field name="arch" type="xml">
            <pivot string="Costo de Nómina por Departamento">
                <field name="department_id" type="row"/>
                <field name="total_earnings" type="measure"/>
                <field name="total_deductions" type="measure"/>
                <field name="net_pay" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_dashboard_payroll_cost" model="ir.actions.act_window">
        <field name="name">Costo de Nómina por Departamento</field>
        <field name="res_model">co.payslip</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="view_payroll_cost_search"/>
        <field name="context">{'search_default_this_year': 1, 'search_default_done': 1}</field>
    </record>

