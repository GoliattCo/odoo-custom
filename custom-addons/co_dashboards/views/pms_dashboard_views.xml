<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         KPI 1 – Reservas por Estado
         ════════════════════════════════════════════════════════════════ -->
    <record id="view_dashboard_reservations_state_graph" model="ir.ui.view">
        <field name="name">pms.reservation.dashboard.state.graph</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <graph string="Reservas por Estado" type="bar">
                <field name="state" type="row"/>
            </graph>
        </field>
    </record>

    <record id="view_dashboard_reservations_state_search" model="ir.ui.view">
        <field name="name">pms.reservation.dashboard.state.search</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <search string="Reservas por Estado">
                <filter name="this_month" string="Este Mes"
                        domain="[('checkin_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('checkin_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('checkin_date', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('checkin_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('checkin_date', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('checkin_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <record id="action_dashboard_reservations_state" model="ir.actions.act_window">
        <field name="name">Reservas por Estado</field>
        <field name="res_model">pms.reservation</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_dashboard_reservations_state_graph"/>
        <field name="search_view_id" ref="view_dashboard_reservations_state_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>

