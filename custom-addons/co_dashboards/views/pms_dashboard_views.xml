        <field name="res_model">pms.reservation</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_dashboard_revenue_channel_graph"/>
        <field name="search_view_id" ref="view_dashboard_revenue_channel_search"/>
        <field name="context">{'search_default_this_year': 1}</field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         KPI 3 – Ocupación y RevPAR
         ════════════════════════════════════════════════════════════════ -->
    <record id="view_dashboard_occupancy_revpar_graph" model="ir.ui.view">
        <field name="name">pms.night.audit.dashboard.occupancy.graph</field>
        <field name="model">pms.night.audit</field>
        <field name="arch" type="xml">
            <graph string="Ocupación y RevPAR" type="line">
                <field name="audit_date" interval="month" type="row"/>
                <field name="occupancy_pct" type="measure"/>
                <field name="revpar" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_dashboard_occupancy_revpar_search" model="ir.ui.view">
        <field name="name">pms.night.audit.dashboard.occupancy.search</field>
        <field name="model">pms.night.audit</field>
        <field name="arch" type="xml">
            <search string="Ocupación y RevPAR">
                <filter name="completed" string="Completado"
                        domain="[('state', '=', 'completed')]"/>
                <filter name="this_month" string="Este Mes"
                        domain="[('audit_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('audit_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('audit_date', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('audit_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('audit_date', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('audit_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <record id="action_dashboard_occupancy_revpar" model="ir.actions.act_window">
        <field name="name">Ocupación y RevPAR</field>
        <field name="res_model">pms.night.audit</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_dashboard_occupancy_revpar_graph"/>
        <field name="search_view_id" ref="view_dashboard_occupancy_revpar_search"/>
        <field name="context">{'search_default_this_year': 1, 'search_default_completed': 1}</field>
    </record>

