<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_board_view" model="ir.ui.view">
        <field name="name">Tablero de Compras</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Tablero de Compras">
                <board style="2-1">
                    <column>
                        <action name="%(co_dashboards.action_dashboard_purchase_requests)d"
                                string="Solicitudes de Compra por Estado"/>
                        <action name="%(co_dashboards.action_dashboard_product_requests)d"
                                string="Solicitudes de Producto por Estado"/>
                        <action name="%(co_dashboards.action_dashboard_purchases_by_dept)d"
                                string="Compras por Departamento"/>
                    </column>
                    <column>
                        <action name="%(co_dashboards.action_dashboard_supplier_scores)d"
                                string="Puntuación de Proveedores"/>
                        <action name="%(co_dashboards.action_dashboard_po_fulfillment)d"
                                string="Cumplimiento de Órdenes de Compra"/>
                        <action name="%(co_dashboards.action_dashboard_requests_priority)d"
                                string="Solicitudes por Prioridad"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_purchase_board" model="ir.actions.act_window">
        <field name="name">Tablero de Compras</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="purchase_board_view"/>
    </record>
</odoo>
