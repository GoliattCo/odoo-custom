<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payroll_board_view" model="ir.ui.view">
        <field name="name">Tablero de Nómina</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Tablero de Nómina">
                <board style="2-1">
                    <column>
                        <action name="%(co_dashboards.action_dashboard_payroll_cost)d"
                                string="Costo de Nómina por Departamento"/>
                        <action name="%(co_dashboards.action_dashboard_employer_contrib)d"
                                string="Aportes Patronales"/>
                        <action name="%(co_dashboards.action_dashboard_provisions)d"
                                string="Provisiones"/>
                        <action name="%(co_dashboards.action_dashboard_overtime)d"
                                string="Horas Extra"/>
                    </column>
                    <column>
                        <action name="%(co_dashboards.action_dashboard_pila)d"
                                string="PILA - Aportes Seguridad Social"/>
                        <action name="%(co_dashboards.action_dashboard_loans)d"
                                string="Préstamos"/>
                        <action name="%(co_dashboards.action_dashboard_hiring)d"
                                string="Solicitudes de Contratación"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_payroll_board" model="ir.actions.act_window">
        <field name="name">Tablero de Nómina</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="payroll_board_view"/>
    </record>
</odoo>
