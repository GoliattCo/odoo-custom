<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_contract_list" model="ir.ui.view">
        <field name="name">hr.contract.list</field>
        <field name="model">hr.contract</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="job_id" optional="show"/>
                <field name="date_start"/>
                <field name="date_end" optional="show"/>
                <field name="wage" sum="Total Wages"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'open'"
                    decoration-warning="state == 'draft'"
                    decoration-danger="state in ('close', 'cancel')"/>
            </list>
        </field>
    </record>

    <record id="view_hr_contract_form" model="ir.ui.view">
        <field name="name">hr.contract.form</field>
        <field name="model">hr.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open" type="object" string="Set to Running"
                        class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" type="object" string="Expire"
                        invisible="state != 'open'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state in ('close', 'cancel')"/>
                    <button name="action_draft" type="object" string="Reset to New"
                        invisible="state not in ('cancel',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,close"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <label for="wage"/>
                            <div class="o_row">
                                <field name="wage"/>
                                <span>/month</span>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_contract_search" model="ir.ui.view">
        <field name="name">hr.contract.search</field>
        <field name="model">hr.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <filter name="running" string="Running" domain="[('state', '=', 'open')]"/>
                <filter name="new" string="New" domain="[('state', '=', 'draft')]"/>
                <group>
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">hr.contract</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_contract_search"/>
    </record>

    <menuitem id="menu_hr_contract"
        name="Contracts"
        parent="hr.menu_hr_root"
        action="action_hr_contract"
        sequence="30"/>

</odoo>
