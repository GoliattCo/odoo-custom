<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_pms_folio_list" model="ir.ui.view">
        <field name="name">pms.folio.list</field>
        <field name="model">pms.folio</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" decoration-bf="1"/>
                <field name="reservation_id"/>
                <field name="guest_id"/>
                <field name="property_id"/>
                <field name="total_charges"/>
                <field name="total_payments"/>
                <field name="balance" decoration-danger="balance > 0"
                    decoration-success="balance == 0"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'closed'"
                    decoration-info="state == 'open'"
                    decoration-muted="state == 'void'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_folio_form" model="ir.ui.view">
        <field name="name">pms.folio.form</field>
        <field name="model">pms.folio</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_invoice" string="Create Invoice"
                        type="object" class="btn-primary"
                        invisible="state != 'open' or invoice_id"/>
                    <button name="action_close" string="Close Folio"
                        type="object"
                        invisible="state != 'open'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="open,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="reservation_id"/>
                            <field name="guest_id"/>
                            <field name="property_id"/>
                        </group>
                        <group>
                            <field name="total_charges"/>
                            <field name="total_payments"/>
                            <field name="balance" decoration-danger="balance > 0"
                                decoration-success="balance == 0"/>
                            <field name="invoice_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Charges" name="charges">
                            <field name="charge_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="product_id"/>
                                    <field name="department"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="amount"/>
                                    <field name="pos_order_id" optional="hide"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payments" name="payments">
                            <field name="payment_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                    <field name="reference"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_folio_search" model="ir.ui.view">
        <field name="name">pms.folio.search</field>
        <field name="model">pms.folio</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="guest_id"/>
                <field name="reservation_id"/>
                <filter name="open" string="Open" domain="[('state','=','open')]"/>
                <filter name="closed" string="Closed" domain="[('state','=','closed')]"/>
                <filter name="with_balance" string="With Balance"
                    domain="[('balance','>',0)]"/>
                <group>
                    <filter name="group_state" string="State"
                        context="{'group_by': 'state'}"/>
                    <filter name="group_property" string="Property"
                        context="{'group_by': 'property_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_folio" model="ir.actions.act_window">
        <field name="name">Folios</field>
        <field name="res_model">pms.folio</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_folio_search"/>
        <field name="path">pms-folios</field>
    </record>

</odoo>
