<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban view — Reservation Board grouped by state -->
    <record id="view_pms_reservation_kanban" model="ir.ui.view">
        <field name="name">pms.reservation.kanban</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="guest_id"/>
                <field name="checkin_date"/>
                <field name="checkout_date"/>
                <field name="nights"/>
                <field name="room_type_id"/>
                <field name="room_id"/>
                <field name="state"/>
                <field name="total_amount"/>
                <field name="source"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex justify-content-between">
                                <strong><field name="name"/></strong>
                                <field name="state" widget="badge"
                                    decoration-success="state == 'checked_in'"
                                    decoration-info="state in ('confirmed','guaranteed')"
                                    decoration-muted="state == 'checked_out'"
                                    decoration-danger="state in ('cancelled','no_show')"/>
                            </div>
                            <div>
                                <i class="fa fa-user"/> <field name="guest_id"/>
                            </div>
                            <div class="text-muted">
                                <field name="checkin_date"/> - <field name="checkout_date"/>
                                (<field name="nights"/> nights)
                            </div>
                            <div class="text-muted">
                                <field name="room_type_id"/>
                                <t t-if="record.room_id.raw_value"> | Rm <field name="room_id"/></t>
                            </div>
                            <div>
                                <strong><field name="total_amount" widget="monetary"/></strong>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar view — Interactive planner -->
    <record id="view_pms_reservation_calendar" model="ir.ui.view">
        <field name="name">pms.reservation.calendar</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <calendar date_start="checkin_date" date_stop="checkout_date"
                color="room_type_id" mode="month"
                event_open_popup="true" quick_create="false">
                <field name="name"/>
                <field name="guest_id"/>
                <field name="room_type_id"/>
                <field name="room_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- List view -->
    <record id="view_pms_reservation_list" model="ir.ui.view">
        <field name="name">pms.reservation.list</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" decoration-bf="1"/>
                <field name="guest_id"/>
                <field name="property_id"/>
                <field name="checkin_date"/>
                <field name="checkout_date"/>
                <field name="nights"/>
                <field name="room_type_id"/>
                <field name="room_id"/>
                <field name="adults"/>
                <field name="children" optional="hide"/>
                <field name="source"/>
                <field name="daily_rate"/>
                <field name="total_amount"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'checked_in'"
                    decoration-info="state in ('confirmed','guaranteed')"
                    decoration-muted="state == 'checked_out'"
                    decoration-danger="state in ('cancelled','no_show')"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_reservation_form" model="ir.ui.view">
        <field name="name">pms.reservation.form</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm"
                        type="object" class="btn-primary"
                        invisible="state not in ('cancelled',)"/>
                    <button name="action_checkin" string="Check In"
                        type="object" class="btn-primary"
                        invisible="state not in ('confirmed','guaranteed')"/>
                    <button name="action_checkout" string="Check Out"
                        type="object" class="btn-primary"
                        invisible="state != 'checked_in'"/>
                    <button name="action_cancel" string="Cancel"
                        type="object"
                        invisible="state not in ('confirmed','guaranteed')"
                        confirm="Are you sure you want to cancel this reservation?"/>
                    <button name="action_no_show" string="No Show"
                        type="object"
                        invisible="state not in ('confirmed','guaranteed')"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="confirmed,checked_in,checked_out"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                            name="action_view_folios"
                            icon="fa-file-text-o"
                            invisible="not folio_ids">
                            <field name="folio_balance" widget="statinfo"
                                string="Folio Balance"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="guest_id"
                                context="{'default_is_hotel_guest': True}"/>
                            <field name="company_guest_id"/>
                            <field name="source"/>
                            <field name="channel_reservation_id"
                                invisible="source not in ('booking_com','expedia','airbnb','despegar','other')"/>
                            <field name="guarantee_type"/>
                        </group>
                        <group>
                            <field name="checkin_date"/>
                            <field name="checkout_date"/>
                            <field name="nights"/>
                            <field name="adults"/>
                            <field name="children"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="room_type_id"
                                domain="[('property_id','=',property_id)]"/>
                            <field name="room_id"
                                domain="[('property_id','=',property_id),('room_type_id','=',room_type_id),('status','=','available')]"/>
                            <field name="rate_plan_id"
                                domain="[('property_id','=',property_id)]"/>
                        </group>
                        <group>
                            <field name="daily_rate"/>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Billing" name="billing">
                            <field name="folio_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="state" widget="badge"/>
                                    <field name="total_charges"/>
                                    <field name="total_payments"/>
                                    <field name="balance"/>
                                </list>
                            </field>
                        </page>
                        <page string="Special Requests" name="requests">
                            <field name="special_requests"
                                placeholder="Guest preferences, special requests, notes..."/>
                        </page>
                        <page string="Cancellation" name="cancellation"
                            invisible="state != 'cancelled'">
                            <group>
                                <field name="cancellation_date"/>
                                <field name="cancellation_reason"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_reservation_search" model="ir.ui.view">
        <field name="name">pms.reservation.search</field>
        <field name="model">pms.reservation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="guest_id"/>
                <field name="room_id"/>
                <field name="room_type_id"/>
                <field name="property_id"/>
                <field name="source"/>
                <separator/>
                <filter name="arrivals_today" string="Arrivals Today"
                    domain="[('checkin_date','=',context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="departures_today" string="Departures Today"
                    domain="[('checkout_date','=',context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="in_house" string="In-House"
                    domain="[('state','=','checked_in')]"/>
                <filter name="confirmed" string="Confirmed"
                    domain="[('state','in',('confirmed','guaranteed'))]"/>
                <filter name="cancelled" string="Cancelled"
                    domain="[('state','=','cancelled')]"/>
                <filter name="no_show" string="No-Show"
                    domain="[('state','=','no_show')]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="State"
                        context="{'group_by': 'state'}"/>
                    <filter name="group_room_type" string="Room Type"
                        context="{'group_by': 'room_type_id'}"/>
                    <filter name="group_source" string="Source"
                        context="{'group_by': 'source'}"/>
                    <filter name="group_property" string="Property"
                        context="{'group_by': 'property_id'}"/>
                    <filter name="group_checkin" string="Check-in Date"
                        context="{'group_by': 'checkin_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_pms_reservation" model="ir.actions.act_window">
        <field name="name">Reservations</field>
        <field name="res_model">pms.reservation</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="search_view_id" ref="view_pms_reservation_search"/>
        <field name="path">pms-reservations</field>
    </record>

    <record id="action_pms_reservation_arrivals" model="ir.actions.act_window">
        <field name="name">Arrivals Today</field>
        <field name="res_model">pms.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_reservation_search"/>
        <field name="context">{'search_default_arrivals_today': 1}</field>
        <field name="path">pms-arrivals</field>
    </record>

    <record id="action_pms_reservation_departures" model="ir.actions.act_window">
        <field name="name">Departures Today</field>
        <field name="res_model">pms.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_reservation_search"/>
        <field name="context">{'search_default_departures_today': 1}</field>
        <field name="path">pms-departures</field>
    </record>

    <record id="action_pms_reservation_in_house" model="ir.actions.act_window">
        <field name="name">In-House Guests</field>
        <field name="res_model">pms.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_reservation_search"/>
        <field name="context">{'search_default_in_house': 1}</field>
        <field name="path">pms-in-house</field>
    </record>

    <record id="action_pms_reservation_walkin" model="ir.actions.act_window">
        <field name="name">Walk-In</field>
        <field name="res_model">pms.reservation</field>
        <field name="view_mode">form</field>
        <field name="context">{
            'default_source': 'walk_in',
            'default_checkin_date': context_today().strftime('%Y-%m-%d'),
        }</field>
        <field name="path">pms-walkin</field>
    </record>

</odoo>
