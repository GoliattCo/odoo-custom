<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_pms_amenity_list" model="ir.ui.view">
        <field name="name">pms.amenity.list</field>
        <field name="model">pms.amenity</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="icon"/>
                <field name="category"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_amenity_form" model="ir.ui.view">
        <field name="name">pms.amenity.form</field>
        <field name="model">pms.amenity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="icon"/>
                        </group>
                        <group>
                            <field name="category"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_amenity_search" model="ir.ui.view">
        <field name="name">pms.amenity.search</field>
        <field name="model">pms.amenity</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <group>
                    <filter name="group_category" string="Category"
                        context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_amenity" model="ir.actions.act_window">
        <field name="name">Amenities</field>
        <field name="res_model">pms.amenity</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_amenity_search"/>
        <field name="path">pms-amenities</field>
    </record>

</odoo>
