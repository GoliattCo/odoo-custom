<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_pms_rate_plan_list" model="ir.ui.view">
        <field name="name">pms.rate.plan.list</field>
        <field name="model">pms.rate.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="property_id"/>
                <field name="rate_type"/>
                <field name="meal_plan"/>
                <field name="is_derived"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="min_stay"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_rate_plan_form" model="ir.ui.view">
        <field name="name">pms.rate.plan.form</field>
        <field name="model">pms.rate.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Best Available Rate"/></h1>
                        <h4 class="text-muted">
                            <field name="code" placeholder="BAR"/>
                        </h4>
                    </div>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="rate_type"/>
                            <field name="meal_plan"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="min_stay"/>
                        </group>
                    </group>
                    <group string="Derivation" invisible="not is_derived">
                        <group>
                            <field name="is_derived"/>
                            <field name="parent_rate_plan_id"/>
                        </group>
                        <group>
                            <field name="derivation_type"/>
                            <field name="derivation_value"/>
                        </group>
                    </group>
                    <group invisible="is_derived">
                        <field name="is_derived"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_rate_plan_search" model="ir.ui.view">
        <field name="name">pms.rate.plan.search</field>
        <field name="model">pms.rate.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="property_id"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
                <group>
                    <filter name="group_type" string="Rate Type"
                        context="{'group_by': 'rate_type'}"/>
                    <filter name="group_meal" string="Meal Plan"
                        context="{'group_by': 'meal_plan'}"/>
                    <filter name="group_property" string="Property"
                        context="{'group_by': 'property_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_rate_plan" model="ir.actions.act_window">
        <field name="name">Rate Plans</field>
        <field name="res_model">pms.rate.plan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_rate_plan_search"/>
        <field name="path">pms-rate-plans</field>
    </record>

</odoo>
