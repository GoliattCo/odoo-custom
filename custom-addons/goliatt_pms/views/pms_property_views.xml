<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_pms_property_list" model="ir.ui.view">
        <field name="name">pms.property.list</field>
        <field name="model">pms.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="property_type"/>
                <field name="star_rating"/>
                <field name="total_rooms"/>
                <field name="partner_id"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_property_form" model="ir.ui.view">
        <field name="name">pms.property.form</field>
        <field name="model">pms.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"
                        options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Hotel name..."/></h1>
                        <h4 class="text-muted">
                            <field name="code" placeholder="HTL01"/>
                        </h4>
                    </div>
                    <group>
                        <group>
                            <field name="property_type"/>
                            <field name="star_rating"/>
                            <field name="partner_id"/>
                            <field name="timezone"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="check_in_time" widget="float_time"/>
                            <field name="check_out_time" widget="float_time"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                            <field name="total_rooms"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Room Types" name="room_types">
                            <field name="room_type_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="bed_type"/>
                                    <field name="max_occupancy"/>
                                    <field name="base_rate"/>
                                    <field name="room_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Rooms" name="rooms">
                            <field name="room_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="room_type_id"/>
                                    <field name="floor"/>
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'available'"
                                        decoration-info="status == 'occupied'"
                                        decoration-warning="status == 'out_of_service'"
                                        decoration-danger="status == 'out_of_order'"/>
                                    <field name="housekeeping_status" widget="badge"
                                        decoration-success="housekeeping_status in ('clean','inspected')"
                                        decoration-warning="housekeeping_status in ('cleaning','pickup')"
                                        decoration-danger="housekeeping_status == 'dirty'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_property_search" model="ir.ui.view">
        <field name="name">pms.property.search</field>
        <field name="model">pms.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
                <group>
                    <filter name="group_type" string="Property Type"
                        context="{'group_by': 'property_type'}"/>
                    <filter name="group_rating" string="Star Rating"
                        context="{'group_by': 'star_rating'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">pms.property</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_property_search"/>
        <field name="path">pms-properties</field>
    </record>

</odoo>
