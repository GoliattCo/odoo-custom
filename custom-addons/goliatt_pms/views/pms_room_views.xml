<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban view — Room Rack grouped by housekeeping status -->
    <record id="view_pms_room_kanban" model="ir.ui.view">
        <field name="name">pms.room.kanban</field>
        <field name="model">pms.room</field>
        <field name="arch" type="xml">
            <kanban default_group_by="housekeeping_status">
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="status"/>
                <field name="housekeeping_status"/>
                <field name="current_guest_name"/>
                <field name="floor"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex justify-content-between">
                                <strong><field name="name"/></strong>
                                <field name="status" widget="badge"
                                    decoration-success="status == 'available'"
                                    decoration-info="status == 'occupied'"
                                    decoration-warning="status == 'out_of_service'"
                                    decoration-danger="status == 'out_of_order'"/>
                            </div>
                            <div class="text-muted">
                                <field name="room_type_id"/> | Floor <field name="floor"/>
                            </div>
                            <div t-if="record.current_guest_name.raw_value">
                                <i class="fa fa-user"/> <field name="current_guest_name"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List view -->
    <record id="view_pms_room_list" model="ir.ui.view">
        <field name="name">pms.room.list</field>
        <field name="model">pms.room</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="property_id"/>
                <field name="floor"/>
                <field name="building" optional="hide"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'available'"
                    decoration-info="status == 'occupied'"
                    decoration-warning="status == 'out_of_service'"
                    decoration-danger="status == 'out_of_order'"/>
                <field name="housekeeping_status" widget="badge"
                    decoration-success="housekeeping_status in ('clean','inspected')"
                    decoration-warning="housekeeping_status in ('cleaning','pickup')"
                    decoration-danger="housekeeping_status == 'dirty'"/>
                <field name="current_guest_name"/>
                <field name="is_smoking" optional="hide"/>
                <field name="is_accessible" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_room_form" model="ir.ui.view">
        <field name="name">pms.room.form</field>
        <field name="model">pms.room</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"
                        statusbar_visible="available,occupied,out_of_order,out_of_service"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="101"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="room_type_id"/>
                            <field name="property_id"/>
                            <field name="floor"/>
                            <field name="building"/>
                        </group>
                        <group>
                            <field name="housekeeping_status" widget="badge"
                                decoration-success="housekeeping_status in ('clean','inspected')"
                                decoration-warning="housekeeping_status in ('cleaning','pickup')"
                                decoration-danger="housekeeping_status == 'dirty'"/>
                            <field name="is_smoking"/>
                            <field name="is_accessible"/>
                            <field name="connecting_room_id"/>
                            <field name="current_reservation_id"/>
                            <field name="current_guest_name"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_room_search" model="ir.ui.view">
        <field name="name">pms.room.search</field>
        <field name="model">pms.room</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="property_id"/>
                <separator/>
                <filter name="available" string="Available"
                    domain="[('status','=','available')]"/>
                <filter name="occupied" string="Occupied"
                    domain="[('status','=','occupied')]"/>
                <filter name="dirty" string="Dirty"
                    domain="[('housekeeping_status','=','dirty')]"/>
                <filter name="clean" string="Clean"
                    domain="[('housekeeping_status','in',('clean','inspected'))]"/>
                <group>
                    <filter name="group_type" string="Room Type"
                        context="{'group_by': 'room_type_id'}"/>
                    <filter name="group_floor" string="Floor"
                        context="{'group_by': 'floor'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                    <filter name="group_hk" string="Housekeeping"
                        context="{'group_by': 'housekeeping_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_pms_room_rack" model="ir.actions.act_window">
        <field name="name">Room Rack</field>
        <field name="res_model">pms.room</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_pms_room_search"/>
        <field name="path">pms-room-rack</field>
    </record>

    <record id="action_pms_room_all" model="ir.actions.act_window">
        <field name="name">All Rooms</field>
        <field name="res_model">pms.room</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_pms_room_search"/>
        <field name="path">pms-rooms</field>
    </record>

</odoo>
