<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Module category ────────────────────────────────────── -->

        <record id="module_category_pms" model="ir.module.category">
            <field name="name">Hotel Management</field>
            <field name="sequence">50</field>
        </record>

        <!-- ── Security Groups ────────────────────────────────────── -->

        <record id="group_pms_user" model="res.groups">
            <field name="name">Front Desk Agent</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Front desk agents — manage reservations, folios, housekeeping, guests.</field>
        </record>

        <record id="group_pms_manager" model="res.groups">
            <field name="name">Hotel Manager</field>
            <field name="implied_ids" eval="[(4, ref('goliatt_pms.group_pms_user'))]"/>
            <field name="comment">Hotel managers — full room, rate, availability, and night-audit management.</field>
        </record>

        <record id="group_pms_admin" model="res.groups">
            <field name="name">PMS Administrator</field>
            <field name="implied_ids" eval="[(4, ref('goliatt_pms.group_pms_manager'))]"/>
            <field name="comment">Full admin — properties, channels, all configuration.</field>
        </record>

        <!-- ── Record Rules ───────────────────────────────────────── -->

        <!-- Users see records belonging to their company -->
        <record id="rule_pms_property_company" model="ir.rule">
            <field name="name">PMS Property: multi-company</field>
            <field name="model_id" ref="model_pms_property"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('goliatt_pms.group_pms_user'))]"/>
        </record>

    </data>
</odoo>
