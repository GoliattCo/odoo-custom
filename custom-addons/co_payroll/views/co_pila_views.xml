<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_co_pila_form" model="ir.ui.view">
        <field name="name">co.pila.form</field>
        <field name="model">co.pila</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate" string="Generate from Payslips"
                            type="object" invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_file" string="Mark as Filed"
                            type="object" invisible="state != 'generated'"
                            class="oe_highlight"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" invisible="state in ('filed', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,generated,filed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="period_month"/>
                            <field name="period_year"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="grand_total" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employee Lines">
                            <field name="line_ids">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="ibc" sum="Total IBC"/>
                                    <field name="eps_employee" sum="EPS EE"/>
                                    <field name="eps_employer" sum="EPS ER"/>
                                    <field name="afp_employee" sum="AFP EE"/>
                                    <field name="afp_employer" sum="AFP ER"/>
                                    <field name="arl" sum="ARL"/>
                                    <field name="caja" sum="Caja"/>
                                    <field name="icbf" sum="ICBF"/>
                                    <field name="sena" sum="SENA"/>
                                    <field name="solidarity_fund" sum="Solidarity"/>
                                    <field name="total" sum="Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Totals">
                            <group>
                                <group>
                                    <field name="total_eps_employee"/>
                                    <field name="total_eps_employer"/>
                                    <field name="total_afp_employee"/>
                                    <field name="total_afp_employer"/>
                                </group>
                                <group>
                                    <field name="total_arl"/>
                                    <field name="total_caja"/>
                                    <field name="total_icbf"/>
                                    <field name="total_sena"/>
                                    <field name="total_solidarity"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_co_pila_list" model="ir.ui.view">
        <field name="name">co.pila.list</field>
        <field name="model">co.pila</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="period_month"/>
                <field name="period_year"/>
                <field name="grand_total" sum="Grand Total"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'generated'"
                       decoration-success="state == 'filed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_co_pila" model="ir.actions.act_window">
        <field name="name">PILA</field>
        <field name="res_model">co.pila</field>
        <field name="view_mode">list,form</field>
        <field name="path">co-pila</field>
    </record>

</odoo>
