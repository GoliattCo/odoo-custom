<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_co_hiring_request_form" model="ir.ui.view">
        <field name="name">co.hiring.request.form</field>
        <field name="model">co.hiring.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_approve" string="Approve"
                            type="object" invisible="state != 'submitted'"
                            class="oe_highlight"
                            groups="co_payroll.group_co_payroll_manager"/>
                    <button name="action_start_recruiting" string="Start Recruiting"
                            type="object" invisible="state != 'approved'"/>
                    <button name="action_mark_filled" string="Mark Filled"
                            type="object" invisible="state != 'recruiting'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" invisible="state in ('filled', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,recruiting,filled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="position"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="number_of_positions"/>
                            <field name="contract_type"/>
                        </group>
                        <group>
                            <field name="requested_by"/>
                            <field name="approved_by"/>
                            <field name="request_date"/>
                            <field name="expected_start_date"/>
                            <field name="salary_range_min"/>
                            <field name="salary_range_max"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Requirements">
                            <field name="requirements"/>
                        </page>
                        <page string="Justification">
                            <field name="justification"/>
                        </page>
                        <page string="Result">
                            <group>
                                <field name="employee_id"/>
                            </group>
                            <field name="notes" placeholder="Notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_co_hiring_request_list" model="ir.ui.view">
        <field name="name">co.hiring.request.list</field>
        <field name="model">co.hiring.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="position"/>
                <field name="department_id"/>
                <field name="contract_type"/>
                <field name="requested_by"/>
                <field name="request_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state in ('approved', 'filled')"
                       decoration-primary="state == 'recruiting'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_co_hiring_request" model="ir.actions.act_window">
        <field name="name">Hiring Requests</field>
        <field name="res_model">co.hiring.request</field>
        <field name="view_mode">list,form</field>
        <field name="path">co-hiring-requests</field>
    </record>

</odoo>
