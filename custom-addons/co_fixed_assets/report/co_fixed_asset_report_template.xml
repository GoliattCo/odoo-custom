<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Report Action ───────────────────────────────────────────────── -->
    <record id="action_report_fixed_asset" model="ir.actions.report">
        <field name="name">Fixed Asset Report</field>
        <field name="model">co.fixed.asset</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">co_fixed_assets.report_fixed_asset_document</field>
        <field name="report_file">co_fixed_assets.report_fixed_asset_document</field>
        <field name="binding_model_id" eval="ref('co_fixed_assets.model_co_fixed_asset')"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ── Report Template ─────────────────────────────────────────────── -->
    <template id="report_fixed_asset_document">
        <t t-call="web.html_container">
            <div class="header" style="border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 16px;">
                <div class="row">
                    <div class="col-3">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)"
                             style="max-height:50px;" alt="Logo"/>
                    </div>
                    <div class="col-9 text-end">
                        <strong t-field="res_company.name" style="font-size: 16px;"/>
                        <br/>
                        <span style="font-size: 11px; color: #666;">Fixed Asset Report</span>
                    </div>
                </div>
            </div>
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-size: 12px;">
                    <h2><t t-out="o.name"/> <small style="color: #888;">(<t t-out="o.code"/>)</small></h2>

                    <table class="table table-sm" style="margin-top: 16px;">
                        <tr>
                            <td style="width: 30%; font-weight: bold;">Category</td>
                            <td><t t-out="o.category_id.name"/></td>
                            <td style="width: 30%; font-weight: bold;">State</td>
                            <td><t t-out="dict(o._fields['state'].selection).get(o.state)"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold;">Serial Number</td>
                            <td><t t-out="o.serial_number or '-'"/></td>
                            <td style="font-weight: bold;">Location</td>
                            <td><t t-out="o.location or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold;">Purchase Date</td>
                            <td><t t-out="o.purchase_date"/></td>
                            <td style="font-weight: bold;">Responsible</td>
                            <td><t t-out="o.responsible_id.name or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold;">Purchase Value</td>
                            <td><span t-field="o.purchase_value" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                            <td style="font-weight: bold;">Salvage Value</td>
                            <td><span t-field="o.salvage_value" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold;">Accumulated Depreciation</td>
                            <td><span t-field="o.accumulated_depreciation" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                            <td style="font-weight: bold;">Book Value</td>
                            <td><span t-field="o.book_value" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold;">Method</td>
                            <td><t t-out="dict(o._fields['depreciation_method'].selection).get(o.depreciation_method)"/></td>
                            <td style="font-weight: bold;">Useful Life</td>
                            <td><t t-out="o.useful_life"/> months</td>
                        </tr>
                    </table>

                    <h4 style="margin-top: 24px;">Depreciation Schedule</h4>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th class="text-end">Amount</th>
                                <th class="text-end">Cumulative</th>
                                <th class="text-end">Remaining</th>
                                <th>Posted</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="cumulative" t-value="0"/>
                            <t t-foreach="o.depreciation_line_ids.sorted('sequence')" t-as="line">
                                <t t-set="cumulative" t-value="cumulative + line.amount"/>
                                <tr>
                                    <td><t t-out="line.sequence"/></td>
                                    <td><t t-out="line.date"/></td>
                                    <td class="text-end">
                                        <span t-field="line.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.cumulative_amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.remaining_value" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                    <td>
                                        <t t-if="line.move_id">Yes</t>
                                        <t t-else="">-</t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <t t-if="o.maintenance_ids">
                        <h4 style="margin-top: 24px;">Maintenance History</h4>
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th class="text-end">Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.maintenance_ids.sorted('date')" t-as="m">
                                    <tr>
                                        <td><t t-out="m.date"/></td>
                                        <td><t t-out="dict(m._fields['maintenance_type'].selection).get(m.maintenance_type)"/></td>
                                        <td><t t-out="m.name"/></td>
                                        <td class="text-end">
                                            <span t-field="m.cost" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </t>
    </template>

</odoo>
