<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_post_depreciation" model="ir.cron">
            <field name="name">Fixed Assets: Monthly Depreciation</field>
            <field name="model_id" ref="model_co_fixed_asset"/>
            <field name="state">code</field>
            <field name="code">model._cron_post_depreciation()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="nextcall" eval="DateTime.now().replace(day=1) + relativedelta(months=1)"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
