<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="account_general_ledger_view_list" model="ir.ui.view">
        <field name="name">account.general.ledger.list</field>
        <field name="model">account.general.ledger</field>
        <field name="arch" type="xml">
            <list string="Libro Mayor"
                  create="false" edit="false" delete="false">
                <field name="account_code" optional="show"/>
                <field name="account_name" optional="hide"/>
                <field name="account_id" column_invisible="1"/>
                <field name="date"/>
                <field name="move_name"/>
                <field name="partner_id"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="debit" sum="Total Debe"/>
                <field name="credit" sum="Total Haber"/>
                <field name="balance" sum="Total Saldo"/>
                <field name="cumulative_balance" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="account_general_ledger_view_pivot" model="ir.ui.view">
        <field name="name">account.general.ledger.pivot</field>
        <field name="model">account.general.ledger</field>
        <field name="arch" type="xml">
            <pivot string="Libro Mayor" disable_linking="True">
                <field name="account_id" type="row"/>
                <field name="debit" type="measure"/>
                <field name="credit" type="measure"/>
                <field name="balance" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="account_general_ledger_view_search" model="ir.ui.view">
        <field name="name">account.general.ledger.search</field>
        <field name="model">account.general.ledger</field>
        <field name="arch" type="xml">
            <search string="Libro Mayor">
                <field name="date" string="Desde"
                       filter_domain="[('date', '&gt;=', self)]"/>
                <field name="account_id" string="Cuenta"/>
                <field name="partner_id" string="Contacto"/>
                <field name="move_id" string="Asiento"/>
                <field name="company_id" string="Empresa"/>
                <field name="cost_center_id" string="Centro de Costo"/>
                <field name="business_unit_id" string="Unidad de Negocio"/>
                <field name="item_code_id" string="Código de Ítem"/>
                <field name="auxiliar_abierto" string="Auxiliar Abierto"/>
                <separator/>
                <filter name="date_from"
                        string="Desde Inicio del Año"
                        domain="[('date', '&gt;=', context_today().strftime('%Y-01-01'))]"/>
                <filter name="date_to"
                        string="Hasta Hoy"
                        domain="[('date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="this_month"
                        string="Este Mes"
                        domain="[
                            ('date', '&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d')),
                            ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))
                        ]"/>
                <group>
                    <filter name="group_by_account" string="Cuenta"
                            context="{'group_by': 'account_id'}"/>
                    <filter name="group_by_partner" string="Contacto"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_date" string="Fecha"
                            context="{'group_by': 'date:month'}"/>
                    <filter string="Empresa" name="group_by_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Centro de Costo" name="group_by_cost_center" context="{'group_by': 'cost_center_id'}"/>
                    <filter string="Unidad de Negocio" name="group_by_business_unit" context="{'group_by': 'business_unit_id'}"/>
                    <filter string="Código de Ítem" name="group_by_item_code" context="{'group_by': 'item_code_id'}"/>
                    <filter string="Auxiliar Abierto" name="group_by_auxiliar" context="{'group_by': 'auxiliar_abierto'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_account_general_ledger" model="ir.actions.act_window">
        <field name="name">Libro Mayor</field>
        <field name="res_model">account.general.ledger</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="account_general_ledger_view_search"/>
        <field name="context">{
            'search_default_date_from': 1,
            'search_default_date_to': 1,
            'search_default_group_by_account': 1,
        }</field>
    </record>

    <!-- Menu: Accounting → Reporting → Libro Mayor -->
    <menuitem id="menu_account_general_ledger"
              name="Libro Mayor"
              parent="account.menu_finance_reports"
              action="action_account_general_ledger"
              sequence="103"/>

</odoo>
