<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit journal items list to add new fields -->
    <record id="view_move_line_list_inherit" model="ir.ui.view">
        <field name="name">account.move.line.list.inherit.co.ext</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="concepto_contable_id" string="Concepto Contable" optional="hide"/>
                <field name="cost_center_id" string="Centro de Costo" optional="hide"/>
                <field name="item_code_id" string="Código de Ítem" optional="hide"/>
                <field name="auxiliar_abierto" string="Aux. Abierto" optional="hide"/>
                <field name="business_unit_id" string="Unidad de Negocio" optional="hide"/>
                <field name="cost_center_notes" string="Notas CC" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit journal items form to add new fields -->
    <record id="view_move_line_form_inherit" model="ir.ui.view">
        <field name="name">account.move.line.form.inherit.co.ext</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Extensiones Colombianas">
                    <group>
                        <field name="concepto_contable_id"/>
                        <field name="cost_center_id"/>
                        <field name="item_code_id"/>
                    </group>
                    <group>
                        <field name="auxiliar_abierto"/>
                        <field name="business_unit_id"/>
                    </group>
                    <field name="cost_center_notes"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Inherit the journal entry form (account.move) to add buttons and new fields -->
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.co.ext</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add Export/Import buttons to header -->
            <xpath expr="//header" position="inside">
                <button name="action_export_journal_entry" type="object"
                        string="Exportar CSV/Excel"
                        invisible="move_type != 'entry'"
                        groups="account.group_account_user"/>
                <button name="action_import_journal_entry" type="object"
                        string="Importar CSV/Excel"
                        invisible="move_type != 'entry' or state != 'draft'"
                        groups="account.group_account_manager"/>
            </xpath>
            <!-- Add Concepto Contable before the Account column -->
            <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']//list//field[@name='account_id']"
                   position="before">
                <field name="concepto_contable_id" string="Concepto" optional="show"/>
            </xpath>
            <!-- Add new columns to the Journal Items tab line_ids list -->
            <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']//list//field[@name='analytic_distribution']"
                   position="after">
                <field name="cost_center_id" string="CC" optional="show"/>
                <field name="item_code_id" string="Ítem" optional="show"/>
                <field name="auxiliar_abierto" string="Aux. Abierto" optional="show"/>
                <field name="business_unit_id" string="UN" optional="show"/>
            </xpath>
            <!-- Add difference field below the journal items notebook -->
            <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']" position="after">
                <group>
                    <group/>
                    <group>
                        <field name="debit_credit_difference" string="Diferencia Débito - Crédito"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
