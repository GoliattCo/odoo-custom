<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="co_accounting_concept_view_list" model="ir.ui.view">
        <field name="name">co.accounting.concept.list</field>
        <field name="model">co.accounting.concept</field>
        <field name="arch" type="xml">
            <list string="Conceptos Contables" default_order="code">
                <field name="code"/>
                <field name="name"/>
                <field name="account_id"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="co_accounting_concept_view_form" model="ir.ui.view">
        <field name="name">co.accounting.concept.form</field>
        <field name="model">co.accounting.concept</field>
        <field name="arch" type="xml">
            <form string="Concepto Contable">
                <sheet>
                    <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ej: Honorarios Profesionales"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="account_id"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción" name="description">
                            <field name="description" placeholder="Descripción del concepto contable..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="co_accounting_concept_view_search" model="ir.ui.view">
        <field name="name">co.accounting.concept.search</field>
        <field name="model">co.accounting.concept</field>
        <field name="arch" type="xml">
            <search string="Conceptos Contables">
                <field name="name" string="Nombre o Código"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="account_id"/>
                <separator/>
                <filter name="archived" string="Archivados"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_account" string="Cuenta"
                            context="{'group_by': 'account_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_co_accounting_concept" model="ir.actions.act_window">
        <field name="name">Conceptos Contables</field>
        <field name="res_model">co.accounting.concept</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="co_accounting_concept_view_search"/>
        <field name="path">co-accounting-concepts</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cree su primer concepto contable
            </p>
            <p>
                Los conceptos contables permiten asociar una cuenta del plan contable
                a un concepto predefinido. Al seleccionar un concepto en un asiento contable,
                la cuenta se asigna automáticamente.
            </p>
        </field>
    </record>

</odoo>
