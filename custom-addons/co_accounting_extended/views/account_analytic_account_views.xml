<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit analytic account form to add cost center fields -->
    <record id="view_account_analytic_account_form_inherit" model="ir.ui.view">
        <field name="name">account.analytic.account.form.inherit.co.ext</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <separator string="Cost Center"/>
                <group>
                    <group>
                        <field name="is_cost_center"/>
                        <field name="cost_center_parent_id"
                               invisible="not is_cost_center"/>
                        <field name="responsible_id"
                               invisible="not is_cost_center"
                               widget="many2one_avatar_user"/>
                    </group>
                    <group invisible="not is_cost_center">
                        <field name="budget_allocated"/>
                        <field name="budget_consumed"/>
                        <field name="budget_remaining"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <field name="cost_center_notes"
                       invisible="not is_cost_center"
                       placeholder="Notes about this cost center..."/>
            </xpath>
        </field>
    </record>

    <!-- Inherit analytic account list to show cost center flag -->
    <record id="view_account_analytic_account_list_inherit" model="ir.ui.view">
        <field name="name">account.analytic.account.list.inherit.co.ext</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="is_cost_center" string="Cost Center" optional="show"/>
                <field name="responsible_id" string="Responsible" optional="hide"
                       widget="many2one_avatar_user"/>
                <field name="budget_allocated" string="Budget" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
