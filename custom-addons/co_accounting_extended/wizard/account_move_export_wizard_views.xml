<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_move_export_wizard_view_form" model="ir.ui.view">
        <field name="name">account.move.export.wizard.form</field>
        <field name="model">account.move.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar Asiento Contable">
                <group>
                    <field name="move_id" readonly="1"/>
                    <field name="export_format"/>
                </group>
                <group invisible="not file_data">
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_export" type="object" string="Exportar" class="btn-primary"
                            invisible="file_data"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_export_wizard" model="ir.actions.act_window">
        <field name="name">Exportar a CSV/Excel</field>
        <field name="res_model">account.move.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
