<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Budget Position: Tree -->
    <!-- ============================================================ -->
    <record id="co_budget_position_view_list" model="ir.ui.view">
        <field name="name">co.budget.position.list</field>
        <field name="model">co.budget.position</field>
        <field name="arch" type="xml">
            <list string="Budget Positions">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="account_ids" widget="many2many_tags"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Budget Position: Form -->
    <!-- ============================================================ -->
    <record id="co_budget_position_view_form" model="ir.ui.view">
        <field name="name">co.budget.position.form</field>
        <field name="model">co.budget.position</field>
        <field name="arch" type="xml">
            <form string="Budget Position">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Operating Expenses"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Accounts" name="accounts">
                            <field name="account_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Budget Position: Search -->
    <!-- ============================================================ -->
    <record id="co_budget_position_view_search" model="ir.ui.view">
        <field name="name">co.budget.position.search</field>
        <field name="model">co.budget.position</field>
        <field name="arch" type="xml">
            <search string="Budget Positions">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Budget Position: Action -->
    <!-- ============================================================ -->
    <record id="action_co_budget_position" model="ir.actions.act_window">
        <field name="name">Budget Positions</field>
        <field name="res_model">co.budget.position</field>
        <field name="view_mode">list,form</field>
        <field name="path">budget-positions</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a budget position
            </p>
            <p>
                Budget positions group accounts for budget tracking.
            </p>
        </field>
    </record>

</odoo>
