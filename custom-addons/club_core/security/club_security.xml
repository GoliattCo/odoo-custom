<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_club_admin" model="res.groups">
            <field name="name">Club Administrator</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_club_staff" model="res.groups">
            <field name="name">Club Staff</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_club_member" model="res.groups">
            <field name="name">Club Member (Portal)</field>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <!-- ── Portal Record Rules ──────────────────────────────────── -->

        <!-- Affiliate: portal user sees only their own record -->
        <record id="rule_affiliate_portal_own" model="ir.rule">
            <field name="name">Affiliate: portal sees own record</field>
            <field name="model_id" ref="model_club_affiliate"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Membership: portal user sees only their own memberships -->
        <record id="rule_membership_portal_own" model="ir.rule">
            <field name="name">Membership: portal sees own memberships</field>
            <field name="model_id" ref="model_club_membership"/>
            <field name="domain_force">[('affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
