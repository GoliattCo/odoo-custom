<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_club_corporate_group_list" model="ir.ui.view">
        <field name="name">club.corporate.group.list</field>
        <field name="model">club.corporate.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="admin_id"/>
                <field name="employee_count" string="Members"/>
                <field name="max_employees"/>
            </list>
        </field>
    </record>

    <record id="view_club_corporate_group_form" model="ir.ui.view">
        <field name="name">club.corporate.group.form</field>
        <field name="model">club.corporate.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_partner_id"/>
                            <field name="admin_id"/>
                        </group>
                        <group>
                            <field name="max_employees"/>
                            <field name="employee_count" readonly="1"/>
                        </group>
                    </group>
                    <field name="employee_ids">
                        <list>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="membership_status"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_club_corporate_group" model="ir.actions.act_window">
        <field name="name">Corporate Groups</field>
        <field name="res_model">club.corporate.group</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
