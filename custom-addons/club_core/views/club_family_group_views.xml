<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_club_family_group_list" model="ir.ui.view">
        <field name="name">club.family.group.list</field>
        <field name="model">club.family.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="primary_member_id"/>
                <field name="billing_affiliate_id"/>
            </list>
        </field>
    </record>

    <record id="view_club_family_group_form" model="ir.ui.view">
        <field name="name">club.family.group.form</field>
        <field name="model">club.family.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <field name="primary_member_id"/>
                        <field name="billing_affiliate_id"/>
                    </group>
                    <field name="dependent_ids">
                        <list>
                            <field name="name"/>
                            <field name="membership_type"/>
                            <field name="membership_status"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_club_family_group" model="ir.actions.act_window">
        <field name="name">Family Groups</field>
        <field name="res_model">club.family.group</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
