# Copy to .env and fill in real values for your environment.
# .env is gitignored; .env.example is the tracked template.
#
# LOCAL DEVELOPMENT ONLY defaults below. Change every value before any
# non-local deployment. Never commit a real .env.

# --- Postgres (docker-compose db service) ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=odoo

# --- Odoo runtime (forwarded to the odoo service via env_file) ---
# Odoo master password gates /web/database/{create,duplicate,drop,backup,restore}.
# Generate with `openssl rand -base64 32`. Required in every environment.
# ADMIN_PASSWORD=

# Optional: Odoo log level (info, debug, warn, error).
# LOG_LEVEL=info
